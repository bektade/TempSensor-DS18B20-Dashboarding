# Copy to .env before: docker compose up -d
TZ=America/Chicago

INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=change-me-influx
INFLUXDB_ORG=tempsensor
INFLUXDB_BUCKET=temperature
INFLUXDB_ADMIN_TOKEN=change-me-influx-admin-token

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana

# MQTT (mqtt-publisher service uses mosquitto; override only for host-side runs)
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_TOPIC=tempsensor/readings
SAMPLE_INTERVAL=60

# CSV log: one new file per publisher run (exports/temp_reading_YYYY-MM-DD_HMMAM.csv)
CSV_DIR=exports

# PNG written on docker compose down (mqtt-publisher stop)
VISUALIZE_OUTPUT_DIR=Visualize/output
