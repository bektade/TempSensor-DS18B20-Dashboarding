# PostgreSQL
POSTGRES_DB=sauna_tests
POSTGRES_USER=sauna_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
DJANGO_DEBUG=1
# With DJANGO_DEBUG=1, any host is allowed (Pi IP, hostname). For production set DEBUG=0 and list hosts explicitly.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change_me_admin_password

# pgAdmin (optional — separate stack in pgadmin/)
PGADMIN_DEFAULT_EMAIL=pgadmin@tempsensor.com
PGADMIN_DEFAULT_PASSWORD=change_me_pgadmin
PGADMIN_PUBLISH_PORT=5050
# pgAdmin connects to Postgres via host port (WebApp must be running)
PGADMIN_POSTGRES_HOST=host.docker.internal
PGADMIN_POSTGRES_PORT=5433

# Import defaults (used when metadata not provided)
DEFAULT_TESTER_NAME=
DEFAULT_SUPPLY_VOLTAGE=
DEFAULT_TOTAL_AMP_DRAW_START=
DEFAULT_RUN_DURATION_MIN=90
DEFAULT_TARGET_TEMPERATURE_F=150
DEFAULT_TEST_LOCATION=
